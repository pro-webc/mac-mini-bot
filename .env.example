# =============================================================================
# mac-mini-bot 環境変数のひな型（本ファイルを .env にコピーして値を埋める。秘密はコミットしない）
# - 各案件は契約プランに応じて TEXT_LLM（Claude Code CLI）が1系統のみ実行（LP / BASIC-CP / STANDARD / ADVANCE）
# - フェンス→app/ 反映・ビルド・GitHub push・Vercel デプロイまで一本化（デプロイ先切替 env はなし）
# - 画像は Manus（nanobananaPro）が生成・配置する（Bot 側の画像 API は未使用）
# - BOT_MAX_CASES 未設定 = キュー内の対象行を全件処理
# =============================================================================

# --- Google Sheets ---
# application_default: scripts/gcloud_application_default_login.sh で Sheets スコープ付き ADC
# service_account: GOOGLE_SHEETS_CREDENTIALS_PATH に JSON（下記コメント参照）
GOOGLE_SHEETS_AUTH_MODE=application_default
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_SHEET_NAME=メイン
# メインの契約が BASIC のとき LP / コーポレート1ページを別シートで判定する場合
# BASIC 案件: B列=パートナー名で行を探し G列（lp / cp_basic）で BASIC_LP vs BASIC-CP を判定
# 未設定時は config の既定スプレッドシート ID が使われる。無効にする場合は空にする。
# GOOGLE_SHEETS_BASIC_SITE_TYPE_SPREADSHEET_ID=
GOOGLE_SHEETS_BASIC_SITE_TYPE_SHEET_NAME=シート1
GOOGLE_SHEETS_BASIC_SITE_TYPE_SKIP_HEADER=true
# service_account 利用時のみ有効（application_default のときは未使用でよい）
# GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-credentials.json

SPREADSHEET_TARGET_AI_STATUS=デモサイト制作中
SPREADSHEET_BOT_REQUIRE_EMPTY_TEST_SITE_URL=true
SPREADSHEET_REQUIRE_HEARING_BODY_NOT_URL=true
# Q 列（ボール保持者）がこの文字列と完全一致の行のみキュー。未設定時は「ポリッシュ」。空にすると条件オフ
# SPREADSHEET_BALL_HOLDER_REQUIRED_TEXT=ポリッシュ
SPREADSHEET_AI_STATUS_ERROR_MAX_LEN=200
# 件数上限（空=全件）。負荷試験のみ例: BOT_MAX_CASES=1
# BOT_MAX_CASES=
# キュー内のうち指定レコード番号だけ処理（例: 再実行）。空で無効
# BOT_ONLY_RECORD_NUMBER=16308
# SPREADSHEET_REQUIRED_FIELDS=record_number,partner_name,contract_plan
# フェーズ期限日（T 列）がこの日以降の行のみ着手。YYYY-MM-DD。未設定時は無効（他条件のみ）。false / off / 0 でも無効
# SPREADSHEET_MIN_PHASE_DEADLINE=2026-03-26

# --- Claude Code CLI（実運用: マニュアル多段チェーン＝本番サイト生成）---
# claude CLI（サブスクリプション認証）。API キー不要。事前に claude auth login で認証済みであること
# subprocess タイムアウト（秒）。長大コード生成向け
CLAUDE_CLI_TIMEOUT_SEC=900
CLAUDE_BASIC_LP_MODEL=claude-opus-4-6
BASIC_LP_USE_CLAUDE_MANUAL=true
BASIC_LP_REFACTOR_AFTER_MANUAL=true

CLAUDE_BASIC_CP_MODEL=claude-opus-4-6
BASIC_CP_USE_CLAUDE_MANUAL=true
BASIC_CP_REFACTOR_AFTER_MANUAL=true

CLAUDE_STANDARD_CP_MODEL=claude-opus-4-6
STANDARD_CP_USE_CLAUDE_MANUAL=true
STANDARD_CP_REFACTOR_AFTER_MANUAL=true
STANDARD_CP_INCLUDE_BLOG_PAGE=true

CLAUDE_ADVANCE_CP_MODEL=claude-opus-4-6
ADVANCE_CP_USE_CLAUDE_MANUAL=true
ADVANCE_CP_REFACTOR_AFTER_MANUAL=true
ADVANCE_CP_INCLUDE_BLOG_PAGE=true


# --- Manus（最終リファクタ・*_REFACTOR_AFTER_MANUAL 時に必須）---
MANUS_API_KEY=your_manus_api_key
MANUS_API_BASE=https://api.manus.ai
MANUS_AGENT_PROFILE=manus-1.6
MANUS_TASK_MODE=agent
# POST /v1/tasks の connectors（公式: https://open.manus.im/docs/connectors ）。未設定時は GitHub コネクタ UUID 1 件。空文字で connectors 省略
# MANUS_TASK_CONNECTORS=bbb0df76-66bd-4a24-ae4f-2aac4750d90b
# false: Create Task の interactiveMode オフ＝自走向け（フォローアップ質問なし・pending になりにくい）。true は人間待ちになりやすい（API が対応している場合）
# MANUS_INTERACTIVE_MODE=false
# true: Manus に GitHub push → 返答末尾 BOT_DEPLOY_GITHUB_URL をシステムが Vercel デプロイに使用（false でローカル push）
MANUS_PROVIDES_DEPLOY_GITHUB_URL=true
# Manus が使う GitHub は「組織用に Manus に接続したアカウント」のみ（運用メモ・プロンプト先頭に明示する用途）
# MANUS_GITHUB_ORG=your-github-org
# MANUS_GITHUB_ACCOUNT_INSTRUCTION='GitHub 操作は組織用に Manus に接続済みのアカウントのみ。別アカウントへの切替は禁止。'
# MANUS_REFACTOR_POLL_INTERVAL_SEC=5
# MANUS_REFACTOR_TIMEOUT_SEC=2700
# MANUS_DEPLOY_GITHUB_REPO_HINT=owner/repo-name

# --- GA4 トラッキング ---
# GA4_MEASUREMENT_ID 設定時は測定IDごと注入。
# GA4_INJECT_TRACKING=true なら ID なしでもトラッキングタグだけ注入可能（後から ID 追加可）。
# 両方未設定のときは注入しない。
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4_INJECT_TRACKING=true

# --- サイト生成・ビルド ---
SITE_IMPLEMENTATION_ENABLED=true
SITE_BUILD_ENABLED=true
# true（既定）: npm build 前に app/**/page.tsx 本数が契約ページ数と一致するか検証する（超過・不足の両方）
# SITE_BUILD_ENFORCE_CONTRACT_PAGE_TSX_COUNT=true
# 以下は一部の .env にあるが現行 config では未参照（運用メモ用にだけ残す場合）
# SITE_BUILD_MAX_FIX_ATTEMPTS=3
# SITE_KEEP_TEMPLATE_APP_ROUTES=false

# --- GitHub ---
GITHUB_TOKEN=your_github_token
GITHUB_USERNAME=your_github_username

# --- デプロイ（AW 列は常に Vercel の公開 URL）---
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id
VERCEL_GIT_REF=main
VERCEL_DEPLOY_USE_GIT_SOURCE=true
VERCEL_FORCE_PUBLIC_DEPLOYMENTS=true

# --- サイト修正ツール（site-annotator）登録 ---
# Vercel デプロイ後に site-annotator へサイトを自動登録する
# 両方が設定されている場合にのみ実行。未設定ならスキップ
SITE_PROVISION_API_URL=https://site-annotator.vercel.app/api/sites/provision
SITE_PROVISION_API_KEY=your_site_provision_api_key

# --- その他 ---
LOG_LEVEL=INFO
OUTPUT_DIR=output
TEMPLATE_DIR=templates
# テスト用（config に定義あり。テキスト LLM は Claude CLI のため通常不要）
# OPENAI_API_KEY=
# 工程テストスナップショットの親ディレクトリ（任意）
# PIPELINE_TEST_RUN_DIR=output/pipeline_test_runs/my_run
# ターミナルログの色: NO_COLOR=1 / FORCE_COLOR=1
# BOT_CONFIG_CHECK=1 python main.py
