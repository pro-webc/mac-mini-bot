# Google Sheets API
# service_account: 下記 JSON（サービスアカウント鍵）。組織で鍵に期限がある場合は application_default を検討
# application_default: JSON 不要。必ず Sheets スコープ付きで: bash scripts/gcloud_application_default_login.sh
GOOGLE_SHEETS_AUTH_MODE=service_account
# application_default のとき必須: Sheets API を有効にした GCP プロジェクト ID（`gcloud config get-value project`）
# GOOGLE_CLOUD_PROJECT=
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
# 案件を読み書きするシート（タブ）名（スプレッドシート上の実名と一致させる。未設定時は Sheet1）
# GOOGLE_SHEETS_SHEET_NAME=メイン
GOOGLE_SHEETS_SHEET_NAME=Sheet1
# メインの契約列が BASIC のとき、LP かコーポレート1ページかを次の別シートで判定する（A=レコード番号 B=パートナー名 G=サイトタイプ「LP」）
# 空のときは照会せず従来どおり BASIC。例の ID は運用シート
# GOOGLE_SHEETS_BASIC_SITE_TYPE_SPREADSHEET_ID=1MGtA2FrSE92msQyQwDrszhL8jaRLIsF6NKb56HhiRRs
# GOOGLE_SHEETS_BASIC_SITE_TYPE_SHEET_NAME=Sheet1
# 1行目が見出しのとき true（既定）
# GOOGLE_SHEETS_BASIC_SITE_TYPE_SKIP_HEADER=true
# 1行目の列見出しが config の SPREADSHEET_HEADER_LABELS と一致しないとき true で起動失敗
# （AV・AW は検証対象外・見出し不要）
SPREADSHEET_HEADERS_STRICT=true
# AI統合ステータス列の値が次と完全一致する行だけ処理（フェーズ名）。既定: デモサイト制作中
SPREADSHEET_TARGET_AI_STATUS=デモサイト制作中
# true のときテストサイトURL列が空の行のみ（未着手のデモ案件）
SPREADSHEET_BOT_REQUIRE_EMPTY_TEST_SITE_URL=true
# true: ヒアリング列が URL（http/https 始まり）の行はスキップ。本文のみ着手
SPREADSHEET_REQUIRE_HEARING_BODY_NOT_URL=true
# フェーズ期限日（T 列）がこの日以降の行のみ着手。YYYY-MM-DD（既定 2026-03-27）。false / off / 0 で無効
# SPREADSHEET_MIN_PHASE_DEADLINE=2026-03-27
# 1回の起動で処理する件数上限（空または0で無制限）。テスト時は 1 や 3 など
# BOT_MAX_CASES=
# AV列（mac-mini）に書くエラー文言の最大長（50〜500、既定200）。短すぎると「要望抽出…」だけで切れる
# SPREADSHEET_AI_STATUS_ERROR_MAX_LEN=200
# 空欄のままだと着手しない必須列（カンマ区切り・SPREADSHEET_COLUMNS のキー名）
# SPREADSHEET_REQUIRED_FIELDS=record_number,partner_name,contract_plan

# 実 LLM 接続時などに使用（業務自動化ではキー必須・各プランのマニュアルを true に）
GEMINI_API_KEY=your_gemini_api_key
# 最終リファクタ（フェンス付きマルチファイル化）は Manus API。マニュアル本編が Gemini かつ *_REFACTOR_AFTER_MANUAL=true のとき必須
# MANUS_API_KEY=
# MANUS_API_BASE=https://api.manus.ai
# MANUS_AGENT_PROFILE=manus-1.6
# MANUS_TASK_MODE=agent
# タスク作成時に有効にするコネクタ UUID（カンマ区切り）。未設定時は GitHub のみ（bbb0df76-… 公式記載）
# OAuth は api では不可。manus.im で事前に GitHub コネクタを連携しておくこと
# https://open.manus.im/docs/connectors
# MANUS_TASK_CONNECTORS=bbb0df76-66bd-4a24-ae4f-2aac4750d90b
# connectors を送らない（空）: MANUS_TASK_CONNECTORS=
# 自走向け: false（既定）= interactiveMode オフ
# MANUS_INTERACTIVE_MODE=false
# MANUS_REFACTOR_POLL_INTERVAL_SEC=5
# MANUS_REFACTOR_TIMEOUT_SEC=2700
# true（既定）: Manus に GitHub push を任せ、返答末尾の BOT_DEPLOY_GITHUB_URL: 行でシステムが Vercel デプロイし、ボットは push しない
# false: ボットがローカルから従来どおり push してから Vercel
# MANUS_PROVIDES_DEPLOY_GITHUB_URL=true
# 任意: Manus プロンプトに渡す push 先の推奨（owner/repo）
# MANUS_DEPLOY_GITHUB_REPO_HINT=
# unary RPC 待ち上限（秒）。長大な Canvas 生成向けに 900 推奨
# GEMINI_RPC_TIMEOUT_SEC=900
# DeadlineExceeded 時の追加試行（0 で再試行なし）
# GEMINI_RPC_DEADLINE_RETRIES=2
# フェンス適用後の TSX 内 ImagePlaceholder を Gemini 画像 API で生成し public/images/generated/ に保存、next/image に置換（GEMINI_API_KEY があるとき常に試行・API 料金に注意）
# 画像専用モデル（Google AI の表記に合わせて変更可）
GEMINI_SITE_IMAGE_MODEL=gemini-3-pro-image-preview
# 1 サイトあたりの最大生成枚数
# GEMINI_SITE_IMAGE_MAX_SLOTS=12
# 連続呼び出しの間隔（秒・レート緩和）
# GEMINI_SITE_IMAGE_DELAY_SEC=1
# 各プランの Gemini マニュアルチェーンは既定 true（モックのみにしたいときだけ false）
# BASIC LP: マニュアル手順どおりの Gemini 多段チェーン
# BASIC_LP_USE_GEMINI_MANUAL=true
# BASIC LP 用モデル（品質優先の既定は config と同じ gemini-3.1-pro-preview。高速重視なら flash 系を指定）
GEMINI_BASIC_LP_MODEL=gemini-3.1-pro-preview
# 手順8のあとリファクタ指示で複数ファイル出力へ（既定 true。push/デプロイは含まない）
# BASIC_LP_REFACTOR_AFTER_MANUAL=true
# BASIC（コーポレート1ページ）: BASIC-CP マニュアルどおりの Gemini 多段チェーン
# BASIC_CP_USE_GEMINI_MANUAL=true
# 未設定時は GEMINI_BASIC_LP_MODEL と同じ
GEMINI_BASIC_CP_MODEL=gemini-3.1-pro-preview
# 手順7-3のあとリファクタ指示で複数ファイル出力へ（既定 true）
# BASIC_CP_REFACTOR_AFTER_MANUAL=true
# STANDARD（コーポレート・6ページ想定）: STANDARD-CP マニュアルどおりの Gemini 多段（タブ①〜⑥・計16回 + 任意リファクタ）
# STANDARD_CP_USE_GEMINI_MANUAL=true
GEMINI_STANDARD_CP_MODEL=gemini-3.1-pro-preview
# マニュアル多段 Gemini の最大出力トークン（手順7の長文コード向け。既定 65536、上限 131072）
# GEMINI_MANUAL_MAX_OUTPUT_TOKENS=65536
# STANDARD_CP_REFACTOR_AFTER_MANUAL=true
# 手順2のブログ独立ページ行を含める（false＝マニュアル「不要なら削除」相当）
# STANDARD_CP_INCLUDE_BLOG_PAGE=true
# ADVANCE（コーポレート・12ページ想定）: ADVANCE-CP マニュアルどおりの Gemini 多段（タブ①〜⑥・計16回 + 任意リファクタ）
# ADVANCE_CP_USE_GEMINI_MANUAL=true
GEMINI_ADVANCE_CP_MODEL=gemini-3.1-pro-preview
# ADVANCE_CP_REFACTOR_AFTER_MANUAL=true
# ADVANCE_CP_INCLUDE_BLOG_PAGE=true
OPENAI_API_KEY=your_openai_api_key

# サイト実装・ローカルビルド検証
SITE_IMPLEMENTATION_ENABLED=true
SITE_BUILD_ENABLED=true

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_USERNAME=your_username

# Vercel（公開 URL をスプレッドシートに書くために必須）
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id
# 既定 true: gitSource（GitHub App 連携・ダッシュボードの Git インポートと同系）。false: zipball+ファイル（App 不要）
# VERCEL_DEPLOY_USE_GIT_SOURCE=true
# GitHub へ push したブランチ名（既定 main）。master 運用なら VERCEL_GIT_REF=master
# VERCEL_GIT_REF=main
# デプロイ後に API で Vercel ログイン保護等を解除し、URL を誰でも閲覧可能にする（false でチーム既定のまま）
VERCEL_FORCE_PUBLIC_DEPLOYMENTS=true

# その他
LOG_LEVEL=INFO
# ターミナルログの色を無効化（https://no-color.org/）
# NO_COLOR=1
# CI など非 TTY でも色付けしたいとき
# FORCE_COLOR=1
OUTPUT_DIR=output
# 工程テストスナップショットの親ディレクトリ（preflight/phase1/work_branch の各 *_snapshots をこの下に）
# PIPELINE_TEST_RUN_DIR=output/pipeline_test_runs/my_run
TEMPLATE_DIR=templates

# 起動時に設定検証のみ（0=正常終了、1=エラー）: BOT_CONFIG_CHECK=1 python main.py
# BOT_CONFIG_CHECK=1
