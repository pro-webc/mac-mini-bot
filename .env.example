# Google Sheets API
# service_account: 下記 JSON（サービスアカウント鍵）。組織で鍵に期限がある場合は application_default を検討
# application_default: JSON 不要。必ず Sheets スコープ付きで: bash scripts/gcloud_application_default_login.sh
GOOGLE_SHEETS_AUTH_MODE=service_account
# application_default のとき必須: Sheets API を有効にした GCP プロジェクト ID（`gcloud config get-value project`）
# GOOGLE_CLOUD_PROJECT=
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
# 案件を読み書きするシート（タブ）名（スプレッドシート上の実名と一致させる。未設定時は Sheet1）
# GOOGLE_SHEETS_SHEET_NAME=メイン
GOOGLE_SHEETS_SHEET_NAME=Sheet1
# 1行目の列見出しが config の SPREADSHEET_HEADER_LABELS と一致しないとき true で起動失敗
SPREADSHEET_HEADERS_STRICT=true
# AI統合ステータス列の値が次と完全一致する行だけ処理（フェーズ名）。既定: デモサイト制作中
SPREADSHEET_TARGET_AI_STATUS=デモサイト制作中
# true のときテストサイトURL列が空の行のみ（未着手のデモ案件）
SPREADSHEET_BOT_REQUIRE_EMPTY_TEST_SITE_URL=true
# true: ヒアリング列が URL（http/https 始まり）の行はスキップ。本文のみ着手
SPREADSHEET_REQUIRE_HEARING_BODY_NOT_URL=true
# 1回の起動で処理する件数上限（空または0で無制限）。テスト時は 1 や 3 など
# BOT_MAX_CASES=
# AV列（mac-mini）に書くエラー文言の最大長（50〜500、既定200）。短すぎると「要望抽出…」だけで切れる
# SPREADSHEET_AI_STATUS_ERROR_MAX_LEN=200
# 空欄のままだと着手しない必須列（カンマ区切り・SPREADSHEET_COLUMNS のキー名）
# SPREADSHEET_REQUIRED_FIELDS=record_number,partner_name,contract_plan

# GEMINI_API_KEY は画像生成（IMAGE_GEN_PROVIDER=gemini）のみ
GEMINI_API_KEY=your_gemini_api_key
# DALL-E 等で IMAGE_GEN_PROVIDER=openai のときに使用
OPENAI_API_KEY=your_openai_api_key

# テキスト LLM（要望抽出・仕様書・サイト実装）: cursor_agent_cli | claude_code_cli
# Cursor: IDE ログインと別。メールは .env に書かない。確認は `agent whoami`（~/.local/bin を PATH に）
# 認証: `agent login` の保存情報、または CURSOR_API_KEY（Cursor 設定で発行）
# 「usage limit / Get Cursor Pro」は無料化とは限らない（Ultra でも CLI 枠で起き得る）→ SETUP.md トラブルシュート「Cursor CLI が usage limit」参照
TEXT_LLM_PROVIDER=cursor_agent_cli
# CURSOR_API_KEY=
CLAUDE_CODE_COMMAND=
# 例: bash scripts/cursor_agent_stdio.sh（main.py はプロジェクトルートの cwd で実行）
CURSOR_AGENT_COMMAND=
# 任意: Cursor agent の --model（未設定ならアカウント既定モデル。有料プランで Named モデル利用可）
# CURSOR_AGENT_MODEL=gpt-5.2
# TEXT_LLM_CLI_TIMEOUT_SEC=1200
# 画像が cursor_agent_cli のときだけ subprocess タイムアウト（秒）。未設定時の既定は 3600（1枚あたり。PNG base64 が重いため TEXT_LLM より長め）。
# TEXT_LLM と同じ 1200 にしたい場合: IMAGE_GEN_CLI_TIMEOUT_SEC=1200
# IMAGE_GEN_CLI_TIMEOUT_SEC=3600

# 画像生成パイプライン（仕様書/サイト実装とは別キー・別コンテキスト推奨）
IMAGE_GEN_ENABLED=false
# openai | gemini | pillow | cursor_agent_cli（cursor は TEXT_LLM と同じ CURSOR_AGENT_COMMAND）
IMAGE_GEN_PROVIDER=gemini
IMAGE_GEN_API_KEY=
# true: IMAGE_GEN_API_KEY が空のとき GEMINI_API_KEY（gemini）/ OPENAI_API_KEY（openai）にフォールバック。専用キー運用なら false
IMAGE_GEN_ALLOW_FALLBACK_TO_MAIN_KEYS=true
# from_placeholder_source: 実装済み TSX の ImagePlaceholder を走査
# standalone_spec: 仕様書の image_requirements のみから生成
IMAGE_GEN_MODE=from_placeholder_source
IMAGE_GEN_AFTER_SITE=true
# IMAGE_GEN_PROVIDER=gemini のとき（既定 gemini-2.5-flash）
# IMAGE_GEN_GEMINI_MODEL=gemini-2.5-flash
IMAGE_GEN_OPENAI_MODEL=dall-e-3
IMAGE_GEN_DALLE_SIZE=1024x1024
# 当該プロセスだけ画像工程をスキップ（IMAGE_GEN_ENABLED は true のまま運用したいとき）。または: python main.py --skip-images / ./run.sh --skip-images
# IMAGE_GEN_SKIP_RUN=1

# サイト実装・ローカルビルド検証
SITE_IMPLEMENTATION_ENABLED=true
SITE_BUILD_ENABLED=true
SITE_BUILD_MAX_FIX_ATTEMPTS=3

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_USERNAME=your_username

# デプロイ列に記録する URL: vercel（既定・gitSource デプロイ）| github（Vercel をスキップし GitHub URL のみ）
# BOT_DEPLOY_URL_SOURCE=vercel

# Vercel（BOT_DEPLOY_URL_SOURCE=vercel のとき必須）
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_vercel_team_id
# 既定 true: gitSource（GitHub App 連携・ダッシュボードの Git インポートと同系）。false: zipball+ファイル（App 不要）
# VERCEL_DEPLOY_USE_GIT_SOURCE=true
# GitHub へ push したブランチ名（既定 main）。master 運用なら VERCEL_GIT_REF=master
# VERCEL_GIT_REF=main
# デプロイ後に API で Vercel ログイン保護等を解除し、URL を誰でも閲覧可能にする（false でチーム既定のまま）
VERCEL_FORCE_PUBLIC_DEPLOYMENTS=true

# プレフライト（scripts/run_preflight_before_push.py）
# 既定: 本番と同じ get_pending_cases() でスプレッドシートから案件取得。Git push / デプロイ / AV・AW 更新のみしない。
# PREFLIGHT_SHEET_ROW_NUMBER=42
# PREFLIGHT_SHEET_CASE_INDEX=0
# 擬似1行のみ（本番と異なる）: PREFLIGHT_SOURCE=env と以下
# PREFLIGHT_HEARING_SHEET_URL=https://docs.google.com/spreadsheets/... またはセルに貼る本文1件分
# 長文はファイルにし: PREFLIGHT_HEARING_SHEET_BODY_FILE=/path/to/hearing.txt
# PREFLIGHT_APPO_MEMO=
# PREFLIGHT_SALES_NOTES=
# PREFLIGHT_CONTRACT_PLAN=STANDARD
# PREFLIGHT_PARTNER_NAME=テストパートナー株式会社
# PREFLIGHT_RECORD_NUMBER=preflight-run

# その他
LOG_LEVEL=INFO
# ターミナルログの色を無効化（https://no-color.org/）
# NO_COLOR=1
# CI など非 TTY でも色付けしたいとき
# FORCE_COLOR=1
OUTPUT_DIR=output
TEMPLATE_DIR=templates

# 起動時に設定検証のみ（0=正常終了、1=エラー）: BOT_CONFIG_CHECK=1 python main.py
# BOT_CONFIG_CHECK=1
